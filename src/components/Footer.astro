---
/**
 * Footer.astro
 * Site footer with Copec branding, quick links, and legal information.
 */
---

<footer class="relative border-t border-border-default bg-copec-blue">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand column -->
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-white/10">
            <svg class="h-6 w-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <div>
            <span class="text-lg font-bold text-white">Red Copec <span class="text-copec-red">Amparo</span></span>
          </div>
        </div>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-blue-200/70">
          Transformando estaciones de servicio en centros de resiliencia comunitaria para la Región del Biobío.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h4 class="mb-4 text-sm font-bold uppercase tracking-wider text-blue-200/90">
          Navegación
        </h4>
        <ul class="space-y-2.5">
          <li>
            <a href="#pilares" class="text-sm text-blue-200/60 transition-colors hover:text-white">Nuestros Pilares</a>
          </li>
          <li>
            <a href="#cobertura" class="text-sm text-blue-200/60 transition-colors hover:text-white">Cobertura</a>
          </li>
          <li>
            <a href="#protocolo" class="text-sm text-blue-200/60 transition-colors hover:text-white">Protocolo de Emergencia</a>
          </li>
          <li>
            <a href="#comunidad" class="text-sm text-blue-200/60 transition-colors hover:text-white">Comunidad</a>
          </li>
          <li>
            <a href="#faq" class="text-sm text-blue-200/60 transition-colors hover:text-white">Preguntas Frecuentes</a>
          </li>
        </ul>
      </div>

      <!-- Emergency -->
      <div>
        <h4 class="mb-4 text-sm font-bold uppercase tracking-wider text-blue-200/90">
          Emergencias
        </h4>
        <ul class="space-y-2.5">
          <li class="flex items-center gap-2 text-sm text-blue-200/60">
            <svg class="h-4 w-4 text-copec-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            <span><strong class="text-white">132</strong> — Bomberos</span>
          </li>
          <li class="flex items-center gap-2 text-sm text-blue-200/60">
            <svg class="h-4 w-4 text-copec-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            <span><strong class="text-white">133</strong> — Carabineros</span>
          </li>
          <li class="flex items-center gap-2 text-sm text-blue-200/60">
            <svg class="h-4 w-4 text-copec-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            <span><strong class="text-white">131</strong> — SAMU</span>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="mb-4 text-sm font-bold uppercase tracking-wider text-blue-200/90">
          Contacto
        </h4>
        <ul class="space-y-2.5">
          <li>
            <a href="mailto:amparo@copec.cl" class="flex items-center gap-2 text-sm text-blue-200/60 transition-colors hover:text-white">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
              amparo@copec.cl
            </a>
          </li>
          <li>
            <a href="https://copec.cl" target="_blank" rel="noopener" class="flex items-center gap-2 text-sm text-blue-200/60 transition-colors hover:text-white">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
              </svg>
              copec.cl
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 border-t border-white/10 pt-8">
      <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
        <p class="text-xs text-blue-200/50">
          © 2025 Copec S.A. Todos los derechos reservados. Red Copec Amparo es un proyecto de resiliencia comunitaria.
        </p>
        <div class="flex items-center gap-4 text-xs text-blue-200/50">
          <a href="#" class="transition-colors hover:text-white">Privacidad</a>
          <span>·</span>
          <a href="#" class="transition-colors hover:text-white">Términos</a>
          <span>·</span>
          <a href="#" class="transition-colors hover:text-white">Accesibilidad</a>
        </div>
      </div>
    </div>
  </div>
</footer>
