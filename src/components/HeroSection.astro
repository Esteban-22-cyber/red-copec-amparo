---
/**
 * HeroSection.astro
 * Impactful hero section with Copec branding and resilience messaging.
 */

// CAMBIA ESTA URL POR LA IMAGEN DE FONDO QUE DESEES
const bgImageUrl = "https://images.unsplash.com/photo-1542382156909-9ae37b3f56fd?q=80&w=2000&auto=format&fit=crop";
---

<section 
  class="relative overflow-hidden bg-cover bg-center bg-no-repeat"
  style={`background-image: url('${bgImageUrl}');`}
>
  <!-- Capa de superposición oscura (Overlay) para legibilidad y contraste accesible -->
  <div class="absolute inset-0 bg-slate-950/75 z-0"></div>

  <!-- Abstract background pattern -->
  <div class="absolute inset-0 opacity-10 z-0">
    <div class="absolute left-1/4 top-0 h-96 w-96 rounded-full bg-copec-red blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 h-80 w-80 rounded-full bg-blue-400 blur-3xl"></div>
    <div class="absolute right-0 top-1/2 h-64 w-64 rounded-full bg-copec-blue-light blur-3xl"></div>
  </div>

  <!-- Grid pattern overlay -->
  <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-40 z-0"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 py-20 sm:px-6 sm:py-28 lg:px-8 lg:py-36">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Text content -->
      <div class="text-center lg:text-left">
        <!-- Badge -->
        <div class="animate-fade-in-up mb-6 inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-2 backdrop-blur-sm">
          <span class="relative flex h-2.5 w-2.5">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-green-400"></span>
          </span>
          <span class="text-xs font-semibold uppercase tracking-wider text-green-300">
            Red Activa — Región del Biobío
          </span>
        </div>

        <!-- Main heading -->
        <h1 class="animate-fade-in-up stagger-1 text-3xl font-extrabold leading-tight tracking-tight text-white sm:text-4xl md:text-5xl lg:text-[3.25rem] xl:text-6xl">
          Red Copec <span class="text-copec-red">Amparo</span>
          <span class="mt-2 block text-2xl font-medium leading-snug text-blue-200 sm:text-3xl md:text-4xl lg:text-[2.5rem]">
            La energía y conexión de tu barrio cuando más lo necesitas
          </span>
        </h1>

        <!-- Subtitle -->
        <p class="animate-fade-in-up stagger-2 mx-auto mt-6 max-w-xl text-base leading-relaxed text-blue-100/80 sm:text-lg lg:mx-0">
          Estaciones de servicio Copec transformadas en centros de resiliencia comunitaria. Energía solar autónoma, conectividad satelital y refugio seguro para tu familia durante emergencias.
        </p>

        <!-- CTA Buttons -->
        <div class="animate-fade-in-up stagger-3 mt-8 flex flex-col items-center gap-4 sm:flex-row lg:justify-start">
          <a
            href="#protocolo"
            class="group inline-flex items-center gap-2 rounded-2xl bg-copec-red px-8 py-4 text-base font-bold text-white shadow-lg transition-all duration-300 hover:bg-copec-red-dark hover:shadow-xl hover:-translate-y-0.5"
          >
            <svg class="h-5 w-5 transition-transform group-hover:scale-110" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z" />
            </svg>
            Protocolo de Emergencia
          </a>
          <a
            href="#pilares"
            class="inline-flex items-center gap-2 rounded-2xl border-2 border-white/30 px-8 py-4 text-base font-semibold text-white backdrop-blur-sm transition-all duration-300 hover:border-white/60 hover:bg-white/10 hover:-translate-y-0.5"
          >
            Conoce la Red
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
        </div>

        <!-- Stats -->
        <div class="animate-fade-in-up stagger-4 mt-10 grid grid-cols-3 gap-6 border-t border-white/10 pt-8">
          <div>
            <span class="text-2xl font-extrabold text-white sm:text-3xl">12</span>
            <p class="mt-1 text-xs font-medium text-blue-200/70 sm:text-sm">Estaciones activas</p>
          </div>
          <div>
            <span class="text-2xl font-extrabold text-white sm:text-3xl">100%</span>
            <p class="mt-1 text-xs font-medium text-blue-200/70 sm:text-sm">Energía solar</p>
          </div>
          <div>
            <span class="text-2xl font-extrabold text-white sm:text-3xl">24/7</span>
            <p class="mt-1 text-xs font-medium text-blue-200/70 sm:text-sm">Disponibilidad</p>
          </div>
        </div>
      </div>

      <!-- Illustration / Visual -->
      <div class="animate-fade-in-up stagger-3 hidden lg:block">
        <div class="relative mx-auto max-w-lg">
          <!-- Main visual container -->
          <div class="relative rounded-3xl border border-white/10 bg-gradient-to-br from-white/10 to-white/5 p-8 shadow-2xl backdrop-blur-lg">
            <!-- Station illustration (stylized) -->
            <div class="flex flex-col items-center gap-6">
              <!-- Solar Panel Icon -->
              <div class="flex h-20 w-20 items-center justify-center rounded-2xl bg-yellow-400/20">
                <svg class="h-12 w-12 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
              </div>
              <div class="h-px w-full bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>

              <!-- Feature mini-cards -->
              <div class="grid w-full grid-cols-2 gap-3">
                <div class="rounded-xl border border-white/10 bg-white/5 p-4 text-center">
                  <svg class="mx-auto mb-2 h-8 w-8 text-blue-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.858 15.355-5.858 21.213 0" />
                  </svg>
                  <span class="text-xs font-medium text-blue-200">Wi-Fi Satelital</span>
                </div>
                <div class="rounded-xl border border-white/10 bg-white/5 p-4 text-center">
                  <svg class="mx-auto mb-2 h-8 w-8 text-green-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                  </svg>
                  <span class="text-xs font-medium text-green-200">Carga USB</span>
                </div>
                <div class="rounded-xl border border-white/10 bg-white/5 p-4 text-center">
                  <svg class="mx-auto mb-2 h-8 w-8 text-red-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                  </svg>
                  <span class="text-xs font-medium text-red-200">Refugio</span>
                </div>
                <div class="rounded-xl border border-white/10 bg-white/5 p-4 text-center">
                  <svg class="mx-auto mb-2 h-8 w-8 text-purple-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5m6 4.125l2.25 2.25m0 0l2.25-2.25M12 13.875V7.5M3.75 7.5h16.5" />
                  </svg>
                  <span class="text-xs font-medium text-purple-200">Medicinas</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Floating badges -->
          <div class="absolute -right-4 -top-4 rounded-xl bg-green-500 px-3 py-2 text-xs font-bold text-white shadow-lg">
            ✓ Autónomo
          </div>
          <div class="absolute -bottom-4 -left-4 rounded-xl bg-copec-red px-3 py-2 text-xs font-bold text-white shadow-lg">
            24/7 Activo
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Wave divider -->
  <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none z-10">
    <svg class="relative block h-12 w-full sm:h-16" viewBox="0 0 1200 120" preserveAspectRatio="none" fill="white">
      <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C57.1,118.92,156.63,69.08,321.39,56.44Z"></path>
    </svg>
  </div>
</section>
