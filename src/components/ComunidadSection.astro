---
/**
 * ComunidadSection.astro
 * Community workshops calendar and strategic alliance trust badges.
 */
const talleres = [
  {
    fecha: '12 Jul',
    titulo: 'Uso correcto de extintores',
    hora: '10:00 — 12:00',
    lugar: 'Estación Copec Concepción Centro',
    categoria: 'Prevención',
    catColor: 'bg-orange-50 text-orange-700',
  },
  {
    fecha: '19 Jul',
    titulo: 'Primeros auxilios básicos',
    hora: '15:00 — 17:30',
    lugar: 'Estación Copec Talcahuano',
    categoria: 'Salud',
    catColor: 'bg-green-50 text-green-700',
  },
  {
    fecha: '26 Jul',
    titulo: 'Plan familiar de emergencia',
    hora: '11:00 — 13:00',
    lugar: 'Estación Copec San Pedro',
    categoria: 'Preparación',
    catColor: 'bg-blue-50 text-blue-700',
  },
  {
    fecha: '02 Ago',
    titulo: 'Evacuación y zonas seguras',
    hora: '09:30 — 11:30',
    lugar: 'Estación Copec Chiguayante',
    categoria: 'Seguridad',
    catColor: 'bg-red-50 text-red-700',
  },
];

const alianzas = [
  { nombre: 'SENAPRED', descripcion: 'Servicio Nacional de Prevención y Respuesta ante Desastres' },
  { nombre: 'Bomberos', descripcion: 'Cuerpo de Bomberos de Chile' },
  { nombre: 'Starlink', descripcion: 'Conectividad Satelital Global' },
  { nombre: 'Cruz Roja', descripcion: 'Cruz Roja Chilena' },
  { nombre: 'ONEMI', descripcion: 'Oficina Nacional de Emergencia' },
];
---

<section id="comunidad" class="relative bg-white py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mx-auto max-w-3xl text-center">
      <span class="inline-block rounded-full bg-copec-blue/10 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-copec-blue">
        Comunidad
      </span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-text-primary sm:text-4xl">
        Prevención y Confianza
      </h2>
      <p class="mt-4 text-base leading-relaxed text-text-secondary sm:text-lg">
        En modo normal, nuestras estaciones se convierten en centros de formación comunitaria para que estés siempre preparado.
      </p>
    </div>

    <!-- Workshop calendar -->
    <div class="mt-14">
      <h3 class="mb-6 flex items-center gap-3 text-xl font-bold text-text-primary">
        <svg class="h-6 w-6 text-copec-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
        </svg>
        Calendario de Talleres — Modo Normal
      </h3>

      <div class="grid gap-4 sm:grid-cols-2">
        {talleres.map((taller) => (
          <div class="group flex gap-4 rounded-2xl border border-border-default bg-white p-5 shadow-card transition-all duration-200 hover:shadow-card-hover hover:border-copec-blue/20">
            <!-- Date badge -->
            <div class="flex h-16 w-16 shrink-0 flex-col items-center justify-center rounded-xl bg-copec-blue text-white">
              <span class="text-lg font-extrabold leading-tight">{taller.fecha.split(' ')[0]}</span>
              <span class="text-[10px] font-semibold uppercase">{taller.fecha.split(' ')[1]}</span>
            </div>

            <!-- Content -->
            <div class="min-w-0 flex-1">
              <div class="flex flex-wrap items-center gap-2">
                <h4 class="text-sm font-bold text-text-primary sm:text-base">{taller.titulo}</h4>
                <span class={`rounded-full px-2.5 py-0.5 text-[10px] font-bold uppercase ${taller.catColor}`}>
                  {taller.categoria}
                </span>
              </div>
              <div class="mt-1.5 flex flex-wrap items-center gap-3 text-xs text-text-muted sm:text-sm">
                <span class="flex items-center gap-1">
                  <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  {taller.hora}
                </span>
                <span class="flex items-center gap-1">
                  <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                  </svg>
                  {taller.lugar}
                </span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Trust badges / Strategic alliances -->
    <div class="mt-20 rounded-3xl border border-border-default bg-surface-secondary p-8 sm:p-12">
      <div class="text-center">
        <h3 class="text-xl font-bold text-text-primary sm:text-2xl">
          Alianzas Estratégicas
        </h3>
        <p class="mt-2 text-sm text-text-secondary sm:text-base">
          Instituciones que respaldan y validan el proyecto Red Copec Amparo
        </p>
      </div>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-6 sm:gap-8">
        {alianzas.map((alianza) => (
          <div class="group flex flex-col items-center gap-2 transition-all duration-200 hover:-translate-y-1">
            <!-- Stylized logo placeholder -->
            <div class="flex h-16 w-28 items-center justify-center rounded-xl border border-border-default bg-white p-3 shadow-card transition-shadow duration-200 group-hover:shadow-card-hover sm:h-20 sm:w-36">
              <div class="text-center">
                <span class="text-sm font-extrabold tracking-tight text-copec-blue sm:text-base">
                  {alianza.nombre}
                </span>
              </div>
            </div>
            <span class="max-w-[120px] text-center text-[10px] text-text-muted sm:max-w-[140px] sm:text-xs">
              {alianza.descripcion}
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
