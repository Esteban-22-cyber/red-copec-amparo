---
/**
 * ProtocoloSection.astro
 * Emergency protocol stepper with vertical/horizontal timeline.
 */
const pasos = [
  {
    numero: 1,
    titulo: 'Dirígete a la Estación',
    descripcion: 'Ubica la estación Copec Amparo más cercana y dirígete de forma ordenada. Sigue la señalética de emergencia instalada en las calles principales.',
    icono: 'map-pin',
    color: 'bg-blue-500',
    colorLight: 'bg-blue-50',
    textColor: 'text-blue-600',
  },
  {
    numero: 2,
    titulo: 'Conéctate a la Red',
    descripcion: 'Conecta tu dispositivo a la red Wi-Fi "Copec Emergencia". Solo WhatsApp y páginas oficiales de rescate estarán habilitadas para asegurar el ancho de banda.',
    icono: 'wifi',
    color: 'bg-green-500',
    colorLight: 'bg-green-50',
    textColor: 'text-green-600',
  },
  {
    numero: 3,
    titulo: 'Carga tu Dispositivo',
    descripcion: 'Usa los tótems de carga rápida disponibles. Cada persona tiene un límite de 15 minutos para garantizar acceso equitativo a todos los asistentes.',
    icono: 'battery',
    color: 'bg-yellow-500',
    colorLight: 'bg-yellow-50',
    textColor: 'text-yellow-600',
  },
  {
    numero: 4,
    titulo: 'Sigue las Instrucciones',
    descripcion: 'Obedece las indicaciones del personal capacitado o las pantallas informativas automáticas. Mantén la calma y ayuda a quienes lo necesiten.',
    icono: 'info',
    color: 'bg-copec-red',
    colorLight: 'bg-red-50',
    textColor: 'text-copec-red',
  },
];
---

<section id="protocolo" class="relative bg-surface-secondary py-20 sm:py-28">
  <!-- Decorative -->
  <div class="absolute right-0 top-0 h-72 w-72 rounded-full bg-copec-red/5 blur-3xl"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mx-auto max-w-3xl text-center">
      <span class="inline-block rounded-full bg-copec-red/10 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-copec-red">
        Guía de Acción
      </span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-text-primary sm:text-4xl">
        Protocolo de Emergencia
      </h2>
      <p class="mt-4 text-base leading-relaxed text-text-secondary sm:text-lg">
        En caso de emergencia, sigue estos 4 pasos simples. Mantén la calma y actúa con orden.
      </p>
    </div>

    <!-- Desktop: Horizontal stepper -->
    <div class="relative mt-16 hidden lg:block">
      <!-- Connection line -->
      <div class="absolute left-0 right-0 top-[3.5rem] h-0.5 bg-gradient-to-r from-blue-200 via-green-200 via-yellow-200 to-red-200"></div>

      <div class="relative grid grid-cols-4 gap-6">
        {pasos.map((paso) => (
          <div class="group relative flex flex-col items-center text-center">
            <!-- Step circle -->
            <div class={`relative z-10 flex h-[4.5rem] w-[4.5rem] items-center justify-center rounded-2xl ${paso.color} text-2xl font-extrabold text-white shadow-lg transition-transform duration-300 group-hover:scale-110`}>
              {paso.numero}
            </div>

            <!-- Content card -->
            <div class={`mt-6 w-full rounded-2xl border border-border-default ${paso.colorLight} p-6 shadow-card transition-all duration-300 group-hover:shadow-card-hover group-hover:-translate-y-1`}>
              <h3 class={`mb-2 text-lg font-bold ${paso.textColor}`}>
                {paso.titulo}
              </h3>
              <p class="text-sm leading-relaxed text-text-secondary">
                {paso.descripcion}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Mobile: Vertical stepper -->
    <div class="mt-12 lg:hidden">
      <div class="relative ml-6 border-l-2 border-border-default pl-8">
        {pasos.map((paso, index) => (
          <div class={`relative pb-10 ${index === pasos.length - 1 ? 'pb-0' : ''}`}>
            <!-- Dot on timeline -->
            <div class={`absolute -left-[calc(2rem+5px)] flex h-10 w-10 items-center justify-center rounded-xl ${paso.color} text-lg font-bold text-white shadow-md`}>
              {paso.numero}
            </div>

            <!-- Content -->
            <div class={`rounded-2xl border border-border-default ${paso.colorLight} p-5 shadow-card`}>
              <h3 class={`mb-2 text-base font-bold ${paso.textColor} sm:text-lg`}>
                {paso.titulo}
              </h3>
              <p class="text-sm leading-relaxed text-text-secondary">
                {paso.descripcion}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Emergency call banner -->
    <div class="mt-14 overflow-hidden rounded-3xl bg-gradient-to-r from-copec-red to-red-700 p-8 text-center shadow-xl sm:p-10">
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center sm:gap-6">
        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-white/20 backdrop-blur-sm">
          <svg class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
        </div>
        <div class="text-white">
          <p class="text-lg font-bold sm:text-xl">En caso de emergencia real, llama al</p>
          <p class="mt-1 text-4xl font-black tracking-wider sm:text-5xl">132</p>
          <p class="mt-1 text-sm font-medium text-red-100">Bomberos de Chile — Emergencias</p>
        </div>
      </div>
    </div>
  </div>
</section>
