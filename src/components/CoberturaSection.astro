---
/**
 * CoberturaSection.astro
 * Two-column layout with an interactive map showing resilient stations.
 */

// Estructura de datos para las estaciones en la Región del Biobío (Tarea 1)
const estaciones = [
  { comuna: 'Concepción', latitud: -36.8201, longitud: -73.0444, estado: 'Activa' },
  { comuna: 'Talcahuano', latitud: -36.7167, longitud: -73.1167, estado: 'Activa' },
  { comuna: 'Chiguayante', latitud: -36.9142, longitud: -73.0247, estado: 'Activa' },
  { comuna: 'San Pedro de la Paz', latitud: -36.8428, longitud: -73.1031, estado: 'Activa' },
  { comuna: 'Hualpén', latitud: -36.7936, longitud: -73.1364, estado: 'Próximamente' },
  { comuna: 'Coronel', latitud: -37.0305, longitud: -73.1422, estado: 'Próximamente' },
  { comuna: 'Tomé', latitud: -36.6186, longitud: -72.9531, estado: 'Próximamente' },
  { comuna: 'Penco', latitud: -36.7381, longitud: -72.9992, estado: 'Próximamente' },
];

const comunas = [
  { nombre: 'Concepción', estado: 'activa' },
  { nombre: 'Talcahuano', estado: 'activa' },
  { nombre: 'Chiguayante', estado: 'activa' },
  { nombre: 'San Pedro de la Paz', estado: 'activa' },
  { nombre: 'Hualpén', estado: 'proximamente' },
  { nombre: 'Coronel', estado: 'proximamente' },
  { nombre: 'Tomé', estado: 'proximamente' },
  { nombre: 'Penco', estado: 'proximamente' },
  { nombre: 'Lota', estado: 'planificada' },
  { nombre: 'Los Ángeles', estado: 'planificada' },
];
---

<section id="cobertura" class="relative bg-white py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mx-auto max-w-3xl text-center">
      <span class="inline-block rounded-full bg-copec-blue/10 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-copec-blue">
        Cobertura
      </span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-text-primary sm:text-4xl">
        Nuestra Red en la Región del Biobío
      </h2>
      <p class="mt-4 text-base leading-relaxed text-text-secondary sm:text-lg">
        Estaciones estratégicamente ubicadas para maximizar la cobertura en zonas de mayor vulnerabilidad.
      </p>
    </div>

    <!-- CDN de Leaflet -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin="" defer></script>

    <!-- Two-column layout -->
    <div class="mt-14 grid items-start gap-10 lg:grid-cols-2 lg:gap-16">
      <!-- Map container (Left) -->
      <div class="relative overflow-hidden rounded-3xl border border-border-default bg-gradient-to-br from-slate-50 to-blue-50 p-2 shadow-lg">
        <div class="relative aspect-[4/3] overflow-hidden rounded-2xl bg-slate-100">
          <!-- Leaflet Map Div (Tarea 1) -->
          <div id="map" class="absolute inset-0 h-full w-full z-0" data-estaciones={JSON.stringify(estaciones)}></div>

          <!-- Map legend (floating over Leaflet Map) -->
          <div class="absolute bottom-4 left-4 rounded-xl border border-border-default bg-white/95 px-4 py-3 shadow-md backdrop-blur-sm pointer-events-none sm:pointer-events-auto z-10">
            <p class="mb-2 text-[10px] font-bold uppercase tracking-wider text-text-muted">Leyenda de la Red</p>
            <div class="flex flex-col gap-1.5">
              <div class="flex items-center gap-2">
                <span class="h-3 w-3 rounded-full bg-copec-red"></span>
                <span class="text-[11px] font-medium text-text-secondary">Estación Activa</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="h-3 w-3 rounded-full bg-orange-400"></span>
                <span class="text-[11px] font-medium text-text-secondary">Próximamente</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="h-3 w-3 rounded-full bg-slate-300"></span>
                <span class="text-[11px] font-medium text-text-secondary">Planificada</span>
              </div>
            </div>
          </div>

          <!-- Region label (floating over Leaflet Map) -->
          <div class="absolute right-4 top-4 rounded-lg bg-copec-blue px-3 py-1.5 text-[11px] font-bold text-white shadow-md pointer-events-none z-10">
            Región del Biobío
          </div>
        </div>
      </div>

      <!-- Communes listing (Right) -->
      <div>
        <h3 class="mb-6 text-xl font-bold text-text-primary">
          Estaciones por Comuna
        </h3>

        <div class="space-y-3">
          {comunas.map((comuna) => (
            <div class="flex items-center justify-between rounded-xl border border-border-default bg-white px-5 py-4 shadow-card transition-all duration-200 hover:shadow-card-hover hover:border-copec-blue/20">
              <div class="flex items-center gap-3">
                <svg class="h-5 w-5 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
                <span class="text-sm font-semibold text-text-primary sm:text-base">{comuna.nombre}</span>
              </div>
              {comuna.estado === 'activa' && (
                <span class="inline-flex items-center gap-1.5 rounded-full bg-green-50 px-3 py-1 text-xs font-bold text-green-700">
                  <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>
                  Activa
                </span>
              )}
              {comuna.estado === 'proximamente' && (
                <span class="inline-flex items-center gap-1.5 rounded-full bg-orange-50 px-3 py-1 text-xs font-bold text-orange-600">
                  <span class="h-1.5 w-1.5 rounded-full bg-orange-400"></span>
                  Próximamente
                </span>
              )}
              {comuna.estado === 'planificada' && (
                <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-50 px-3 py-1 text-xs font-bold text-slate-500">
                  <span class="h-1.5 w-1.5 rounded-full bg-slate-300"></span>
                  Planificada
                </span>
              )}
            </div>
          ))}
        </div>

        <!-- Call to action -->
        <div class="mt-8 rounded-2xl border border-copec-blue/10 bg-gradient-to-r from-copec-blue/5 to-blue-50 p-6">
          <p class="text-sm font-medium text-text-secondary">
            <span class="font-bold text-copec-blue">¿Tu comuna aún no está en la lista?</span> Estamos expandiendo la red constantemente. Contáctanos para solicitar la evaluación de tu zona.
          </p>
          <button class="mt-3 inline-flex items-center gap-2 rounded-xl bg-copec-blue px-5 py-2.5 text-sm font-semibold text-white transition-all hover:bg-copec-blue-dark hover:shadow-md">
            Solicitar Evaluación
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Inicialización de mapa de Leaflet en el cliente (Tarea 1)
  function initMap() {
    const mapElement = document.getElementById('map');
    if (!mapElement) return;

    const estaciones = JSON.parse(mapElement.getAttribute('data-estaciones') || '[]');

    const run = () => {
      // @ts-ignore
      const L = window.L;
      if (!L) {
        setTimeout(run, 100);
        return;
      }

      // Evita reinicializaciones si ya se creó el mapa en transiciones de página
      // @ts-ignore
      if (mapElement._leaflet_id) return;

      const map = L.map('map', {
        center: [-36.8122971, -73.0865063],
        zoom: 10,
        zoomControl: true,
        scrollWheelZoom: false
      });

      // Capa de mapa (CartoDB Positron / Voyager para diseño limpio y profesional)
      L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
        subdomains: 'abcd',
        maxZoom: 20
      }).addTo(map);

      // Marcadores HTML personalizados con colores
      const createCustomIcon = (color: string) => {
        return L.divIcon({
          className: 'custom-div-icon',
          html: `<div class="relative flex items-center justify-center">
            <span class="absolute inline-flex h-6 w-6 animate-ping rounded-full opacity-35" style="background-color: ${color};"></span>
            <span class="relative inline-flex h-4 w-4 rounded-full border-2 border-white shadow-md" style="background-color: ${color};"></span>
          </div>`,
          iconSize: [24, 24],
          iconAnchor: [12, 12]
        });
      };

      const iconActiva = createCustomIcon('#E21C24'); // Rojo Copec
      const iconProxima = createCustomIcon('#F97316'); // Naranja

      estaciones.forEach((estacion: any) => {
        const icon = estacion.estado === 'Activa' ? iconActiva : iconProxima;
        
        L.marker([estacion.latitud, estacion.longitud], { icon })
          .addTo(map)
          .bindPopup(`
            <div class="p-2 font-sans min-w-[120px]">
              <strong class="text-sm text-slate-800 block mb-1">${estacion.comuna}</strong>
              <span class="inline-flex items-center gap-1.5 rounded-full px-2 py-0.5 text-[10px] font-bold ${estacion.estado === 'Activa' ? 'bg-red-50 text-red-700' : 'bg-orange-50 text-orange-700'}">
                <span class="h-1.5 w-1.5 rounded-full ${estacion.estado === 'Activa' ? 'bg-red-500' : 'bg-orange-500'}"></span>
                Estación ${estacion.estado}
              </span>
            </div>
          `);
      });
    };

    run();
  }

  // Cargar en carga inicial y soporte de View Transitions
  document.addEventListener('DOMContentLoaded', initMap);
  document.addEventListener('astro:page-load', initMap);
</script>
