---
/**
 * CoberturaSection.astro
 * Two-column layout with a stylized map and commune listing.
 */
const comunas = [
  { nombre: 'Concepción', estado: 'activa' },
  { nombre: 'Talcahuano', estado: 'activa' },
  { nombre: 'Chiguayante', estado: 'activa' },
  { nombre: 'San Pedro de la Paz', estado: 'activa' },
  { nombre: 'Hualpén', estado: 'proximamente' },
  { nombre: 'Coronel', estado: 'proximamente' },
  { nombre: 'Tomé', estado: 'proximamente' },
  { nombre: 'Penco', estado: 'proximamente' },
  { nombre: 'Lota', estado: 'planificada' },
  { nombre: 'Los Ángeles', estado: 'planificada' },
];
---

<section id="cobertura" class="relative bg-white py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mx-auto max-w-3xl text-center">
      <span class="inline-block rounded-full bg-copec-blue/10 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-copec-blue">
        Cobertura
      </span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-text-primary sm:text-4xl">
        Nuestra Red en la Región del Biobío
      </h2>
      <p class="mt-4 text-base leading-relaxed text-text-secondary sm:text-lg">
        Estaciones estratégicamente ubicadas para maximizar la cobertura en zonas de mayor vulnerabilidad.
      </p>
    </div>

    <!-- Two-column layout -->
    <div class="mt-14 grid items-start gap-10 lg:grid-cols-2 lg:gap-16">
      <!-- Map placeholder (Left) -->
      <div class="relative overflow-hidden rounded-3xl border border-border-default bg-gradient-to-br from-slate-50 to-blue-50 p-2 shadow-lg">
        <div class="relative aspect-[4/3] overflow-hidden rounded-2xl bg-gradient-to-br from-copec-blue/5 to-blue-100/30">
          <!-- Stylized map background -->
          <div class="absolute inset-0 flex items-center justify-center">
            <!-- SVG map outline of Biobío (simplified) -->
            <svg class="h-full w-full opacity-20" viewBox="0 0 400 300" fill="none">
              <!-- Simplified coastline -->
              <path d="M80 20 C90 40, 70 80, 85 120 C95 150, 75 180, 90 220 C100 250, 80 270, 95 290" stroke="#003B71" stroke-width="2" fill="none" stroke-dasharray="4 2"/>
              <!-- Landmass shape -->
              <path d="M85 20 L280 30 C300 35, 320 60, 310 90 C300 120, 330 150, 320 180 C310 210, 290 240, 280 270 L90 290 C80 270, 100 250, 90 220 C75 180, 95 150, 85 120 C70 80, 90 40, 80 20Z" fill="#003B71" fill-opacity="0.04" stroke="#003B71" stroke-width="1" stroke-opacity="0.15"/>
              <!-- Rivers -->
              <path d="M160 80 C180 100, 200 90, 220 110" stroke="#60A5FA" stroke-width="1.5" fill="none" opacity="0.4"/>
              <path d="M120 160 C150 170, 170 165, 200 180" stroke="#60A5FA" stroke-width="1" fill="none" opacity="0.3"/>
            </svg>
          </div>

          <!-- Map pins -->
          <div class="absolute inset-0">
            <!-- Concepción -->
            <div class="absolute" style="top: 35%; left: 35%;">
              <div class="relative">
                <span class="pin-ping absolute inline-flex h-4 w-4 rounded-full bg-copec-red opacity-30"></span>
                <span class="relative inline-flex h-4 w-4 rounded-full border-2 border-white bg-copec-red shadow-md"></span>
              </div>
              <span class="absolute left-5 top-0 whitespace-nowrap rounded-md bg-white/90 px-2 py-0.5 text-[10px] font-bold text-copec-blue shadow-sm backdrop-blur-sm">Concepción</span>
            </div>

            <!-- Talcahuano -->
            <div class="absolute" style="top: 28%; left: 28%;">
              <div class="relative">
                <span class="pin-ping absolute inline-flex h-4 w-4 rounded-full bg-copec-red opacity-30"></span>
                <span class="relative inline-flex h-4 w-4 rounded-full border-2 border-white bg-copec-red shadow-md"></span>
              </div>
              <span class="absolute left-5 top-0 whitespace-nowrap rounded-md bg-white/90 px-2 py-0.5 text-[10px] font-bold text-copec-blue shadow-sm backdrop-blur-sm">Talcahuano</span>
            </div>

            <!-- Chiguayante -->
            <div class="absolute" style="top: 42%; left: 48%;">
              <div class="relative">
                <span class="pin-ping absolute inline-flex h-4 w-4 rounded-full bg-copec-red opacity-30"></span>
                <span class="relative inline-flex h-4 w-4 rounded-full border-2 border-white bg-copec-red shadow-md"></span>
              </div>
              <span class="absolute left-5 top-0 whitespace-nowrap rounded-md bg-white/90 px-2 py-0.5 text-[10px] font-bold text-copec-blue shadow-sm backdrop-blur-sm">Chiguayante</span>
            </div>

            <!-- San Pedro -->
            <div class="absolute" style="top: 50%; left: 32%;">
              <div class="relative">
                <span class="pin-ping absolute inline-flex h-4 w-4 rounded-full bg-copec-red opacity-30"></span>
                <span class="relative inline-flex h-4 w-4 rounded-full border-2 border-white bg-copec-red shadow-md"></span>
              </div>
              <span class="absolute left-5 top-0 whitespace-nowrap rounded-md bg-white/90 px-2 py-0.5 text-[10px] font-bold text-copec-blue shadow-sm backdrop-blur-sm">San Pedro</span>
            </div>

            <!-- Hualpén (upcoming) -->
            <div class="absolute" style="top: 30%; left: 38%;">
              <span class="relative inline-flex h-3.5 w-3.5 rounded-full border-2 border-white bg-orange-400 shadow-md opacity-70"></span>
            </div>

            <!-- Coronel (upcoming) -->
            <div class="absolute" style="top: 65%; left: 30%;">
              <span class="relative inline-flex h-3.5 w-3.5 rounded-full border-2 border-white bg-orange-400 shadow-md opacity-70"></span>
              <span class="absolute left-5 top-0 whitespace-nowrap rounded-md bg-white/80 px-2 py-0.5 text-[10px] font-medium text-orange-600 shadow-sm">Coronel</span>
            </div>
          </div>

          <!-- Map legend -->
          <div class="absolute bottom-4 left-4 rounded-xl border border-border-default bg-white/90 px-4 py-3 shadow-md backdrop-blur-sm">
            <p class="mb-2 text-[10px] font-bold uppercase tracking-wider text-text-muted">Leyenda</p>
            <div class="flex flex-col gap-1.5">
              <div class="flex items-center gap-2">
                <span class="h-3 w-3 rounded-full bg-copec-red"></span>
                <span class="text-[11px] font-medium text-text-secondary">Estación Activa</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="h-3 w-3 rounded-full bg-orange-400"></span>
                <span class="text-[11px] font-medium text-text-secondary">Próximamente</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="h-3 w-3 rounded-full bg-slate-300"></span>
                <span class="text-[11px] font-medium text-text-secondary">Planificada</span>
              </div>
            </div>
          </div>

          <!-- Region label -->
          <div class="absolute right-4 top-4 rounded-lg bg-copec-blue px-3 py-1.5 text-[11px] font-bold text-white shadow-md">
            Región del Biobío
          </div>
        </div>
      </div>

      <!-- Communes listing (Right) -->
      <div>
        <h3 class="mb-6 text-xl font-bold text-text-primary">
          Estaciones por Comuna
        </h3>

        <div class="space-y-3">
          {comunas.map((comuna) => (
            <div class="flex items-center justify-between rounded-xl border border-border-default bg-white px-5 py-4 shadow-card transition-all duration-200 hover:shadow-card-hover hover:border-copec-blue/20">
              <div class="flex items-center gap-3">
                <svg class="h-5 w-5 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
                <span class="text-sm font-semibold text-text-primary sm:text-base">{comuna.nombre}</span>
              </div>
              {comuna.estado === 'activa' && (
                <span class="inline-flex items-center gap-1.5 rounded-full bg-green-50 px-3 py-1 text-xs font-bold text-green-700">
                  <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>
                  Activa
                </span>
              )}
              {comuna.estado === 'proximamente' && (
                <span class="inline-flex items-center gap-1.5 rounded-full bg-orange-50 px-3 py-1 text-xs font-bold text-orange-600">
                  <span class="h-1.5 w-1.5 rounded-full bg-orange-400"></span>
                  Próximamente
                </span>
              )}
              {comuna.estado === 'planificada' && (
                <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-50 px-3 py-1 text-xs font-bold text-slate-500">
                  <span class="h-1.5 w-1.5 rounded-full bg-slate-300"></span>
                  Planificada
                </span>
              )}
            </div>
          ))}
        </div>

        <!-- Call to action -->
        <div class="mt-8 rounded-2xl border border-copec-blue/10 bg-gradient-to-r from-copec-blue/5 to-blue-50 p-6">
          <p class="text-sm font-medium text-text-secondary">
            <span class="font-bold text-copec-blue">¿Tu comuna aún no está en la lista?</span> Estamos expandiendo la red constantemente. Contáctanos para solicitar la evaluación de tu zona.
          </p>
          <button class="mt-3 inline-flex items-center gap-2 rounded-xl bg-copec-blue px-5 py-2.5 text-sm font-semibold text-white transition-all hover:bg-copec-blue-dark hover:shadow-md">
            Solicitar Evaluación
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>
